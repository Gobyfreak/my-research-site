---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer style="border-top: 1px solid var(--divider); background-color: var(--bg-card);">
  <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

    <!-- Col 1: Name + bio + copyright -->
    <div class="lg:col-span-1">
      <a href={base} class="font-display font-bold text-lg leading-tight hover:underline" style="color: var(--accent);">
        Christos Gkenas
      </a>
      <p class="mt-2 text-sm leading-relaxed" style="color: var(--text-muted);">
        Freshwater ecologist at MARE,<br />University of Lisbon.
      </p>
      <p class="mt-4 text-xs" style="color: var(--text-faint);">
        © {year} Christos Gkenas.<br />All rights reserved.
      </p>
    </div>

    <!-- Col 2: Quick Links -->
    <div>
      <h4 class="font-sans font-semibold text-xs uppercase tracking-widest mb-4" style="color: var(--text); letter-spacing: 0.1em;">Quick Links</h4>
      <ul class="flex flex-col gap-2.5 text-sm" style="color: var(--text-muted);">
        {[
          { href: `${base}publications`, label: 'Publications' },
          { href: `${base}conferences`, label: 'Talks' },
          { href: `${base}projects`, label: 'Projects' },
          { href: `${base}contact`, label: 'Contact' },

        ].map(({ href, label, external }) => (
          <li>
            <a
              href={href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
              class="hover:underline transition-colors"
              style="color: var(--text-muted);"
              onmouseover="this.style.color='var(--accent)';"
              onmouseout="this.style.color='var(--text-muted)';"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Contact -->
    <div>
      <h4 class="font-sans font-semibold text-xs uppercase tracking-widest mb-4" style="color: var(--text); letter-spacing: 0.1em;">Contact</h4>
      <div class="flex flex-col gap-2 text-sm" style="color: var(--text-muted);">
        <p>Christos Gkenas</p>
        <p class="text-xs leading-relaxed" style="color: var(--text-faint);">
          Junior Researcher in Freshwater Ecology<br />
          MARE · University of Lisbon
        </p>
        <a
          href="mailto:cgkenas@ciencias.ulisboa.pt"
          class="hover:underline transition-colors mt-1"
          style="color: var(--accent);"
        >
          cgkenas@ciencias.ulisboa.pt
        </a>
      </div>
    </div>

    <!-- Col 4: Connect (social icons) -->
    <div>
      <h4 class="font-sans font-semibold text-xs uppercase tracking-widest mb-4" style="color: var(--text); letter-spacing: 0.1em;">Connect</h4>
      <div class="flex gap-3 flex-wrap">
        <!-- GitHub -->
        <a href="https://github.com/Gobyfreak" target="_blank" rel="noopener noreferrer" aria-label="GitHub"
          style="color: var(--text-muted);"
          onmouseover="this.style.color='var(--accent)';"
          onmouseout="this.style.color='var(--text-muted)';">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
        <!-- Email -->
        <a href="mailto:cgkenas@ciencias.ulisboa.pt" aria-label="Email"
          style="color: var(--text-muted);"
          onmouseover="this.style.color='var(--accent)';"
          onmouseout="this.style.color='var(--text-muted)';">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/in/christos-gkenas-a5ab7028/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
          style="color: var(--text-muted);"
          onmouseover="this.style.color='var(--accent)';"
          onmouseout="this.style.color='var(--text-muted)';">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <!-- Twitter / X -->
        <a href="https://x.com/cgkenas" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X"
          style="color: var(--text-muted);"
          onmouseover="this.style.color='var(--accent)';"
          onmouseout="this.style.color='var(--text-muted)';">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <!-- ORCID -->
        <a href="https://orcid.org/0000-0002-9863-2289" target="_blank" rel="noopener noreferrer" aria-label="ORCID"
          style="color: var(--text-muted);"
          onmouseover="this.style.color='var(--accent)';"
          onmouseout="this.style.color='var(--text-muted)';">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 3.881-1.544 3.881-3.722 0-2.178-1.522-3.722-3.881-3.722h-2.297z"/></svg>
        </a>
        <!-- ResearchGate -->
        <a href="https://www.researchgate.net/profile/Christos_Gkenas" target="_blank" rel="noopener noreferrer" aria-label="ResearchGate"
          style="color: var(--text-muted);"
          onmouseover="this.style.color='var(--accent)';"
          onmouseout="this.style.color='var(--text-muted)';">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.586 0c-.818 0-1.508.19-2.073.565-.563.377-.97.936-1.213 1.68a12.195 12.195 0 0 0-.32 1.233 8.1 8.1 0 0 0-.098 1.599 6.8 6.8 0 0 0 .56 2.787c.375.863.92 1.54 1.62 2.024.7.487 1.51.73 2.434.73.72 0 1.37-.195 1.955-.586a4.43 4.43 0 0 0 1.423-1.623c.362-.693.543-1.46.543-2.299V6.08h-4.117v1.494h2.52c-.063.617-.26 1.107-.593 1.475-.33.367-.782.55-1.35.55-.57 0-1.064-.15-1.477-.447-.41-.3-.725-.726-.94-1.283a5.33 5.33 0 0 1-.323-1.937c0-.714.103-1.35.308-1.907.21-.557.51-.99.912-1.3.4-.31.876-.467 1.43-.467.493 0 .91.12 1.25.358.34.24.61.594.8 1.065l1.608-.66a4.3 4.3 0 0 0-1.38-1.822C21.047.26 20.37 0 19.586 0zM0 24h4.5V10.5H0V24zm2.25-15.75a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5zM9 24h4.5V16.5c0-1.66 1.34-3 3-3s3 1.34 3 3V24H24v-7.5c0-4.14-3.36-7.5-7.5-7.5S9 12.36 9 16.5V24z"/></svg>
        </a>
      </div>
    </div>

  </div>
</footer>
