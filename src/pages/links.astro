---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allLinks = await getCollection('links');

// Group by category
const grouped = allLinks.reduce((acc, link) => {
  const cat = link.data.category;
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(link);
  return acc;
}, {} as Record<string, typeof allLinks>);

const categoryOrder = ['Academic Profiles', 'Code & Data', 'Lab & Institution'];
const sortedCategories = [
  ...categoryOrder.filter((c) => grouped[c]),
  ...Object.keys(grouped).filter((c) => !categoryOrder.includes(c)),
];
---

<BaseLayout title="Links" description="Useful links and profiles for Christos Gkenas.">
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <h1 class="font-display font-bold tracking-tight mb-2" style="font-size: 2.5rem; color: var(--text);">Links</h1>
    <p class="text-sm mb-12" style="color: var(--text-muted);">Academic profiles, code repositories, and resources</p>

    <div class="flex flex-col gap-12 max-w-2xl">
      {sortedCategories.map((cat) => (
        <div>
          <h2 class="font-display font-semibold text-sm uppercase tracking-wider mb-4" style="color: var(--text-faint);">{cat}</h2>
          <div class="flex flex-col gap-3">
            {grouped[cat].map((link) => (
              <a
                href={link.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start justify-between gap-4 p-4 rounded-xl transition-all"
                style="border: 1px solid var(--border); background-color: var(--bg-card);"
                onmouseover="this.style.borderColor='var(--border-strong)';"
                onmouseout="this.style.borderColor='var(--border)';"
              >
                <div class="flex flex-col gap-0.5 min-w-0">
                  <span class="font-display font-semibold text-sm transition-colors group-hover:text-[color:var(--accent)]" style="color: var(--text);">
                    {link.data.title}
                  </span>
                  <span class="text-xs truncate" style="color: var(--text-muted);">{link.data.description}</span>
                </div>
                <svg class="w-4 h-4 flex-shrink-0 transition-colors mt-0.5 group-hover:text-[color:var(--accent)]" style="color: var(--text-faint);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
