---
interface Props {
  size?: 'sm' | 'md';
}
const { size = 'md' } = Astro.props;
const iconSize = size === 'sm' ? 'w-4 h-4' : 'w-5 h-5';
const linkClass = size === 'sm'
  ? 'p-2 rounded-md transition-colors social-link'
  : 'p-2.5 rounded-lg transition-colors social-link';

