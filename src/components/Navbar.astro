---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const pubDropdown = [
  { href: `${base}publications/peer-reviewed`, label: 'Peer-Reviewed' },
  { href: `${base}publications/theses`, label: 'Theses' },
  { href: `${base}publications/other`, label: 'Other' },
];

const isPubActive = currentPath.startsWith(`${base}publications`);

const commDropdown = [
  { href: `${base}conferences/oral`, label: 'Oral Talks' },
  { href: `${base}conferences/posters`, label: 'Posters' },
];

const isCommActive = currentPath.startsWith(`${base}conferences`);

const links = [
  { href: `${base}projects`, label: 'Projects' },
  { href: `${base}contact`, label: 'Contact' },
];
---

<header
  class="sticky top-0 z-50 backdrop-blur-md border-b"
  style="background-color: var(--nav-bg); border-color: var(--border);"
>
  <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <a
      href={base}
      class="font-sans font-semibold tracking-tight transition-colors"
      style="font-size: 1rem; color: var(--text);"
      onmouseover="this.style.color='var(--accent)'"
      onmouseout="this.style.color='var(--text)'"
    >
      Christos Gkenas
    </a>

    <ul class="flex gap-5 items-center" style="font-size: 0.9rem; font-weight: 500;">
      <!-- Home -->
      <li>
        <a
          href={base}
          class="transition-colors pb-0.5"
          style={currentPath === base ? 'color: var(--accent); border-bottom: 2px solid var(--accent);' : 'color: var(--text-muted);'}
          onmouseover="if(this.style.borderBottom==='') this.style.color='var(--accent)';"
          onmouseout="if(this.style.borderBottom==='') this.style.color='var(--text-muted)';"
        >
          Home
        </a>
      </li>

      <!-- Publications dropdown -->
      <li class="relative group">
        <button
          class="flex items-center gap-1 transition-colors pb-0.5"
          style={isPubActive ? 'color: var(--accent); border-bottom: 2px solid var(--accent);' : 'color: var(--text-muted);'}
          aria-haspopup="true"
        >
          Publications
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"/>
          </svg>
        </button>

        <div
          class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-48 rounded-lg overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 origin-top scale-95 group-hover:scale-100"
          style="background-color: var(--nav-bg); border: 1px solid var(--border); box-shadow: 0 8px 24px rgba(0,0,0,0.12); backdrop-filter: blur(40px) saturate(150%);"
        >
          <ul class="py-1.5">
            {pubDropdown.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="block px-4 py-2 text-sm font-medium transition-colors"
                  style="color: var(--text-muted);"
                  onmouseover="this.style.backgroundColor='var(--accent-bg)'; this.style.color='var(--accent)';"
                  onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--text-muted)';"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </li>

      <!-- Communications dropdown -->
      <li class="relative group">
        <button
          class="flex items-center gap-1 transition-colors pb-0.5"
          style={isCommActive ? 'color: var(--accent); border-bottom: 2px solid var(--accent);' : 'color: var(--text-muted);'}
          aria-haspopup="true"
        >
          Communications
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"/>
          </svg>
        </button>

        <div
          class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-48 rounded-lg overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 origin-top scale-95 group-hover:scale-100"
          style="background-color: var(--nav-bg); border: 1px solid var(--border); box-shadow: 0 8px 24px rgba(0,0,0,0.12); backdrop-filter: blur(40px) saturate(150%);"
        >
          <ul class="py-1.5">
            {commDropdown.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="block px-4 py-2 text-sm font-medium transition-colors"
                  style="color: var(--text-muted);"
                  onmouseover="this.style.backgroundColor='var(--accent-bg)'; this.style.color='var(--accent)';"
                  onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--text-muted)';"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </li>

      <!-- Other links -->
      {links.map(({ href, label }) => {
        const isActive = currentPath.startsWith(href) && href !== base;
        return (
          <li>
            <a
              href={href}
              class="transition-colors pb-0.5"
              style={isActive ? 'color: var(--accent); border-bottom: 2px solid var(--accent);' : 'color: var(--text-muted);'}
              onmouseover="if(!this.style.borderBottom || this.style.borderBottom==='') this.style.color='var(--accent)';"
              onmouseout="if(!this.style.borderBottom || this.style.borderBottom==='') this.style.color='var(--text-muted)';"
            >
              {label}
            </a>
          </li>
        );
      })}

      <!-- Dark mode toggle -->
      <li>
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="p-2 rounded-lg transition-colors"
          style="color: var(--text-muted);"
        >
          <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="4"/>
            <path stroke-linecap="round" d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
          <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const sun = document.getElementById('icon-sun');
  const moon = document.getElementById('icon-moon');
  const html = document.documentElement;

  function applyTheme(dark: boolean) {
    if (dark) {
      html.classList.add('dark');
      sun?.classList.remove('hidden');
      moon?.classList.add('hidden');
      localStorage.setItem('theme', 'dark');
    } else {
      html.classList.remove('dark');
      sun?.classList.add('hidden');
      moon?.classList.remove('hidden');
      localStorage.setItem('theme', 'light');
    }
  }

  applyTheme(html.classList.contains('dark'));

  toggle?.addEventListener('click', () => {
    applyTheme(!html.classList.contains('dark'));
  });
</script>
